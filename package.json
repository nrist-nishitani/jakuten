{
  "name": "jakuten-store",
  "version": "2.2.0",
  "description": "E-commerce application with Node.js v26 and modern dependencies",
  "main": "app.js",
  "engines": {
    "node": ">=26.4.0"
  },
  "scripts": {
    "bundle": "webpack",
    "start": "node bundle.js",
    "generate-sea-config": "node generate-sea-config.js",
    "build:sea": "node --experimental-sea-config sea-config.json",
    "build:sea:windows": "powershell -ExecutionPolicy Bypass -File build-sea.ps1",
    "build:sea:unix": "bash build-sea.sh"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.3.0",
    "cookie-parser": "^1.4.7",
    "ejs": "^6.0.1",
    "finalhandler": "^2.1.1",
    "fs": "0.0.1-security",
    "md5": "^2.3.0",
    "router": "^2.2.0"
  },
  "bin": {
    "jakuten-store": "bin/index.js"
  },
  "pkg": {
    "scripts": "bin/**/*.js",
    "assets": "resources/**/*"
  },
  "devDependencies": {
    "postject": "^1.0.0-alpha.6",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  }
}
